# macOS
.DS_Store

# Local environment and secrets
.htaccess
wp-config.php
wp-config-sample.php
wp-content/debug.log

# WordPress core and generated root files
.well-known/
license.txt
readme.html
wordfence-waf.php
index.php
wp-blog-header.php
