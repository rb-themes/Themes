# Ignore everything in wp-content by default.
wp-content/*

# Keep theme source under version control.
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/hitboox/
!wp-content/themes/hitboox/**
!wp-content/themes/hitboox-child/
!wp-content/themes/hitboox-child/**
!wp-content/themes/index.php

# Keep maintenance and migration control code under version control.
!wp-content/mu-plugins/
!wp-content/mu-plugins/cygma-maintenance.php

# Ignore generated content, backups, and large binary artifacts.
wp-content/ai1wm-backups/
wp-content/cache/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/uploads/
wp-content/wflogs/

# Ignore plugins for now; add explicit exceptions later if custom plugins are introduced.
wp-content/plugins/
